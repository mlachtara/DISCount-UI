# ─────────────────────────────────────────────────────────────────────────────
# SETUP: copy this file to .env and fill in the values below.
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials to the repo.
# Get the Azure values from the project lead (share via Slack/Discord/email).
# ─────────────────────────────────────────────────────────────────────────────

# ── Storage ──────────────────────────────────────────────────────────────────
# Set to "true" to use shared Azure Blob Storage (images & models are shared
# between all team members).  Set to "false" to store files locally instead.
USE_AZURE_STORAGE=true

# Required when USE_AZURE_STORAGE=true.
# Full connection string — get this from the project lead.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Azure Blob container name — get this from the project lead.
AZURE_STORAGE_CONTAINER_NAME=imgblob

# Path used for local (non-Azure) file storage (only used when USE_AZURE_STORAGE=false)
LOCAL_STORAGE_PATH=./local_storage

# ── Database ──────────────────────────────────────────────────────────────────
# Each developer has their own local SQLite database (jobs, tiles, labels).
# This file is gitignored so your labeling progress stays on your machine.
# If you want a shared database, swap this URL for a PostgreSQL/Azure SQL URL.
DATABASE_URL=sqlite+aiosqlite:///./discount.db

# ── Server ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Detector ─────────────────────────────────────────────────────────────────
# Confidence threshold for YOLO detections (0.0–1.0)
DETECTOR_CONFIDENCE=0.20
# Minimum floor for g(s) — ensures every tile has a non-zero sampling probability
DETECTOR_EPSILON=0.5

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT session tokens.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
