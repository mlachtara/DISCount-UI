# Copy this file to .env and fill in values before running.

# ── Storage ──────────────────────────────────────────────────────────────────
# Set to "true" to use Azure Blob Storage; anything else falls back to local disk.
USE_AZURE_STORAGE=false

# Only required when USE_AZURE_STORAGE=true
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=discount-ui

# Path used for local (non-Azure) file storage
LOCAL_STORAGE_PATH=./local_storage

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./discount.db

# ── Server ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Detector ─────────────────────────────────────────────────────────────────
# Confidence threshold used when running YOLO
DETECTOR_CONFIDENCE=0.25
# Small constant added to every g(s) to ensure no tile has zero probability
DETECTOR_EPSILON=0.5
